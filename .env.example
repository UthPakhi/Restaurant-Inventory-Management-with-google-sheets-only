# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_CLIENT_ID: For Google OAuth.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: For Google OAuth.
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# GOOGLE_REDIRECT_URI: Usually APP_URL + /api/auth/callback
GOOGLE_REDIRECT_URI="MY_GOOGLE_REDIRECT_URI"

# FIREBASE_SERVICE_ACCOUNT: Optional but recommended for server-side firebase operations
# Can be a JSON string.
# FIREBASE_SERVICE_ACCOUNT='{}'
